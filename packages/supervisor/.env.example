# Default Provider Configuration (optional)
# Set these to auto-create a provider on first run
SS_PROVIDER_ID=my-provider              # Provider ID (required to auto-create)
SS_PROVIDER_NAME=My Provider            # Display name (optional, defaults to ID)
SS_PROVIDER_API_TYPE=anthropic-messages # API type: anthropic-messages or openai-compatible
SS_PROVIDER_BASE_URL=                   # Base URL (optional)
SS_PROVIDER_API_KEY=                    # API key (optional, will be encrypted)
SS_PROVIDER_ICON=                       # Icon path (optional, e.g., /icons/minimax.svg)

# Encryption Configuration (for API key encryption)
# Option 1: Use salt + password (auto-generates 32-byte key)
SS_ENCRYPTION_SALT=your_random_salt_here
SS_MASTER_PASSWORD=your_secure_password_here

# Option 2: Direct 32-byte hex key (64 hex characters, overrides Option 1)
# SS_API_KEY_ENCRYPTION_KEY=your_64_character_hex_key_here

# Test Provider Configuration (for integration tests)
# These are used by test/integration/helpers.ts to create mock provider/model
TEST_PROVIDER_ID=test-minimax
TEST_PROVIDER_NAME=Test MiniMax
TEST_PROVIDER_API_TYPE=anthropic-messages
TEST_PROVIDER_BASE_URL=https://api.minimaxi.com/anthropic
TEST_PROVIDER_API_KEY=your_test_api_key_here      # Also accepts MINIMAX_CN_API_KEY
TEST_PROVIDER_ICON=

TEST_MODEL_ID=MiniMax-M2.7
TEST_MODEL_NAME=MiniMax M2.7
TEST_MODEL_CONTEXT_WINDOW=128000
TEST_MODEL_MAX_TOKENS=16384
TEST_MODEL_SUPPORTS_MULTIMODAL=false
