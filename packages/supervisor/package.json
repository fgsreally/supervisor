{
  "name": "@earendil-works/pi-supervisor",
  "version": "0.1.0",
  "description": "Supervisor for managing multiple pi agent sessions",
  "bin": {
    "pi-supervisor": "./dist/cli.mjs"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/types.d.mts",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/index.mjs"
    },
    "./testing/ai": {
      "types": "./dist/testing/ai/index.d.mts",
      "import": "./dist/testing/ai/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "shx rm -rf dist",
    "dev": "tsdown --watch",
    "serve:playground": "node dist/cli.mjs serve --port 3030 --cwd ../../playground --db ../../playground/.supervisor/supervisor.db",
    "build": "tsdown",
    "test": "vitest --run --config vitest.config.ts",
    "test:unit": "vitest --run --config vitest.config.ts",
    "test:ai": "vitest --run --config vitest.ai.config.ts",
    "test:all": "pnpm run test:unit && pnpm run test:ai"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@hono/node-server": "^1.14.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@puppeteer/browsers": "^2.8.0",
    "better-sqlite3": "^11.10.0",
    "hono": "^4.8.4",
    "ignore": "^6.0.2",
    "jiti": "^2.7.0",
    "prompts": "^2.4.2",
    "puppeteer-core": "^24.8.0",
    "typebox": "^1.3.3",
    "typescript": "^5.7.3",
    "uuid": "^14.0.0",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/prompts": "^2.4.9",
    "shx": "^0.4.0",
    "tsdown": "^0.22.3",
    "unrun": "^0.3.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
