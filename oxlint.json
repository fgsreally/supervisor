{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-console": "off",
    "no-explicit-any": "off"
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/dist-chrome/**",
    "**/dist-firefox/**",
    "**/*.generated.ts",
    "**/test-sessions.ts"
  ]
}
